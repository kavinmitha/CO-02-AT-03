#include <iostream>
using namespace std;

class Team
{
private:
    string teamName;
    int wins, draws, losses;
    int goalsScored, goalsConceded;

public:
    void getData()
    {
        cout << "Enter Team Name: ";
        cin >> teamName;

        cout << "Enter Wins: ";
        cin >> wins;

        cout << "Enter Draws: ";
        cin >> draws;

        cout << "Enter Losses: ";
        cin >> losses;

        cout << "Enter Goals Scored: ";
        cin >> goalsScored;

        cout << "Enter Goals Conceded: ";
        cin >> goalsConceded;

        if (wins < 0 || draws < 0 || losses < 0)
        {
            wins = draws = losses = 0;
        }
    }

    int getPoints()
    {
        return (wins * 3) + draws;
    }

    int getGoalDifference()
    {
        return goalsScored - goalsConceded;
    }

    string getName()
    {
        return teamName;
    }

    void display()
    {
        cout << "\nTeam: " << teamName;
        cout << "\nPoints: " << getPoints();
        cout << "\nGoal Difference: "
             << getGoalDifference() << endl;
    }
};

int main()
{
    int groups;

    cout << "Enter Number of Groups: ";
    cin >> groups;

    string champion;
    int championPoints = -1;
    int totalTeams = 0;

    for (int i = 0; i < groups; i++)
    {
        int n;

        cout << "\nEnter Number of Teams in Group "
             << i + 1 << ": ";
        cin >> n;

        totalTeams += n;

        Team t[10];

        int maxPoints = -1;
        string winner;

        for (int j = 0; j < n; j++)
        {
            cout << "\nTeam " << j + 1 << endl;
            t[j].getData();

            if (t[j].getPoints() > maxPoints)
            {
                maxPoints = t[j].getPoints();
                winner = t[j].getName();
            }
        }

        cout << "\nGroup " << i + 1
             << " Winner: " << winner << endl;

        if (maxPoints > championPoints)
        {
            championPoints = maxPoints;
            champion = winner;
        }
    }

    cout << "\nOverall Champion: "
         << champion << endl;

    cout << "Total Teams: "
         << totalTeams << endl;

    return 0;
}
